;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Money or Honey"
config/description="Papers, Please tarzı banka vezneci oyunu - sahte para tespiti"
run/main_scene="res://scenes/main/MainMenu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
LevelManager="*res://scripts/autoload/LevelManager.gd"
ScoringSystem="*res://scripts/autoload/ScoringSystem.gd"
CurrencyDatabase="*res://scripts/autoload/CurrencyDatabase.gd"

